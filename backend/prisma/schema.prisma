generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MENTOR
  ADMIN
}

enum CallType {
  RESUME_REVAMP
  JOB_GUIDANCE
  MOCK_INTERVIEW
}

enum CallStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id                 String    @id @default(uuid())
  name               String
  email              String    @unique
  password           String
  role               Role      @default(USER)
  timezone           String    @default("UTC")
  description        String?
  createdAt          DateTime  @default(now()) @map("created_at")

  availabilityAsUser Availability[] @relation("UserAvailability")
  availabilityAsMentor Availability[] @relation("MentorAvailability")
  meetingsAsAdmin    Meeting[] @relation("AdminMeetings")
  userTags           UserTag[] @relation("UserTags")
  mentorTags         MentorTag[] @relation("MentorTags")
  callsAsUser        Call[]    @relation("CallsUser")
  callsAsMentor      Call[]    @relation("CallsMentor")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique

  userTags   UserTag[]
  mentorTags MentorTag[]

  @@map("tags")
}

model UserTag {
  userId String
  tagId  String

  user User @relation("UserTags", fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
}

model MentorTag {
  mentorId String
  tagId    String

  mentor User @relation("MentorTags", fields: [mentorId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mentorId, tagId])
  @@map("mentor_tags")
}

model Call {
  id             String     @id @default(uuid())
  userId         String
  mentorId       String
  callType       CallType
  scheduledTime  DateTime   @db.Timestamp(3)
  status         CallStatus @default(PENDING)
  createdByAdmin Boolean    @default(false)
  createdAt      DateTime   @default(now()) @map("created_at")

  user   User @relation("CallsUser", fields: [userId], references: [id], onDelete: Cascade)
  mentor User @relation("CallsMentor", fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("calls")
}

model Availability {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  mentorId  String?  @map("mentor_id")
  role      Role
  date      DateTime @db.Date
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")

  user   User? @relation("UserAvailability", fields: [userId], references: [id], onDelete: Cascade)
  mentor User? @relation("MentorAvailability", fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([userId, date, startTime], map: "availabilities_user_id_date_start_time_key")
  @@unique([mentorId, date, startTime], map: "availabilities_mentor_id_date_start_time_key")
  @@index([userId], map: "availabilities_user_id_idx")
  @@index([mentorId], map: "availabilities_mentor_id_idx")
  @@index([role], map: "availabilities_role_idx")
  @@index([date], map: "availabilities_date_idx")
  @@index([userId, date], map: "availabilities_user_id_date_idx")
  @@index([mentorId, date], map: "availabilities_mentor_id_date_idx")
  @@index([role, date], map: "availabilities_role_date_idx")
  @@map("availabilities")
}

model Meeting {
  id              String   @id @default(uuid())
  adminId         String   @map("admin_id")
  title           String
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  meetLink        String?  @map("meet_link")
  calendarEventId String?  @map("calendar_event_id")
  googleEventId   String?  @map("google_event_id")
  createdAt       DateTime @default(now()) @map("created_at")

  admin        User                 @relation("AdminMeetings", fields: [adminId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String @id @default(uuid())
  meetingId String @map("meeting_id")
  email     String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@map("meeting_participants")
}

